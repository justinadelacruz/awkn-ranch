{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/programs/layout,_N_T_/[lang]/programs/page,_N_T_/es/programs"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/programs/__PAGE__",
    "/$d$lang/programs",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}