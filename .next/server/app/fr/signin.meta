{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/signin/layout,_N_T_/[lang]/signin/page,_N_T_/fr/signin"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/signin/__PAGE__",
    "/$d$lang/signin",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}