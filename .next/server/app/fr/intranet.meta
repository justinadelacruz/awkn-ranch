{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/intranet/layout,_N_T_/[lang]/intranet/page,_N_T_/fr/intranet"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/intranet/__PAGE__",
    "/$d$lang/intranet",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}